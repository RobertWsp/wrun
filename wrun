# Restore default SIGPIPE so `wrun cmd | head`, `wrun cmd | less -q`, etc. exit
# quietly on pipe close instead of raising BrokenPipeError tracebacks.
# Python installs SIG_IGN by default for SIGPIPE in interpreters.
try:
    signal.signal(signal.SIGPIPE, signal.SIG_DFL)
except (AttributeError, ValueError):
    # AttributeError on Windows (no SIGPIPE); ValueError off the main thread.
    pass


# ─── Constants ────────────────────────────────────────────────────────────────

ANSI_RE = re.compile(
    r"\x1b\[[0-9;]*[a-zA-Z]"       # CSI sequences (colors, cursor)
    r"|\x1b\].*?(?:\x07|\x1b\\)"   # OSC sequences (hyperlinks, titles) - BEL or ST terminator
    r"|\x1b\(B"                     # Character set selection
    r"|\x1b\[\?[0-9;]*[a-zA-Z]"    # Private mode sequences
    r"|]8;;[^\x07\x1b]*(?:\x07|\x1b\\|\\\\|\s)"  # Residual OSC 8 hyperlinks after partial strip
)
DECORATIVE_RE = re.compile(r"^[\s=\-_~*]{3,}\s*$")
_TRUNCATION_RE = re.compile(r"\+\d+ more\b|\.\.\. \(\d+")
PROGRESS_RE = re.compile(r"^\s*[\|/\\\-]\s|^\s*\d+%\s*[\|█▓▒░]|^\.{4,}(?:\s*\[?\s*\d+%\s*\]?)?\s*$")
TIMESTAMP_ONLY_RE = re.compile(r"^\[?\d{4}[-/]\d{2}[-/]\d{2}[\sT]\d{2}:\d{2}:\d{2}[^\]]*\]?\s*$")

DEFAULT_MAX_FAILURES = 10
DEFAULT_MAX_LINES = 15
OUTPUT_DIR = Path.home() / ".local" / "share" / "wrun"

# Framework internal paths to skip in stack traces
SKIP_FRAMES = {
    "site-packages",
    "_pytest",
    "pluggy",
    "node_modules",
    "_pydevd",
    "importlib",
    "unittest/",
    "asyncio/",
    "concurrent/futures",
    "threading.py",
}

