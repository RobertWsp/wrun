#!/usr/bin/env python3
"""wrun - Bash Wrapper: Optimized command output for AI consumption.

Wraps any bash command, captures output, and produces a minimal
token-efficient summary. Designed for test runners, linters, type
checkers, and build tools.

Usage:
    wrun <command> [args...]
    wrun --full <command> [args...]
    wrun --json <command> [args...]
    <command> 2>&1 | wrun --stdin [--tool pytest]

Options:
    --full              Show full output (bypass optimization)
    --max-failures N    Max failures to display (default: 10)
    --max-lines N       Max error lines per failure (default: 15)
    --json              Output as JSON
    -q, --quiet         Summary line only
    --no-save           Don't save full output to disk
    --stdin             Read from stdin instead of executing command
    --tool TOOL         Hint tool type when using --stdin
    -h, --help          Show this help

Examples:
    wrun uv run pytest -x tests/
    wrun bun test src/
    wrun ruff check .
    wrun tsc --noEmit
    wrun make build
    pytest tests/ 2>&1 | wrun --stdin --tool pytest

Shell integration (auto-wrap):
    source ~/.local/share/wrun/integration.zsh
    export WRUN_AUTO=1

Optimization techniques:
    - ANSI color stripping
    - Relative path normalization (worktree-aware)
    - Show only failures (skip passing tests)
    - Truncate stack traces (skip framework internals)
    - Group lint errors by rule
    - Remove decorative/progress lines
    - Cap output (max failures, max lines per failure)
    - Deduplicate identical errors
    - 1-line summary for passing runs
"""

from __future__ import annotations

import json
import os
import re
import subprocess
import sys
import time
from abc import ABC, abstractmethod
from dataclasses import asdict, dataclass, field
from datetime import datetime
from pathlib import Path
from typing import Optional


# ─── Constants ────────────────────────────────────────────────────────────────

ANSI_RE = re.compile(
    r"\x1b\[[0-9;]*[a-zA-Z]"       # CSI sequences (colors, cursor)
    r"|\x1b\].*?(?:\x07|\x1b\\)"   # OSC sequences (hyperlinks, titles) - BEL or ST terminator
    r"|\x1b\(B"                     # Character set selection
    r"|\x1b\[\?[0-9;]*[a-zA-Z]"    # Private mode sequences
    r"|]8;;[^\x07\x1b]*(?:\x07|\x1b\\|\\\\|\s)"  # Residual OSC 8 hyperlinks after partial strip
)
DECORATIVE_RE = re.compile(r"^[\s=\-_~*]{3,}\s*$")
_TRUNCATION_RE = re.compile(r"\+\d+ more\b|\.\.\. \(\d+")
PROGRESS_RE = re.compile(r"^\s*[\|/\\\-]\s|^\s*\d+%\s*[\|█▓▒░]|^\.{4,}$")
TIMESTAMP_ONLY_RE = re.compile(r"^\[?\d{4}[-/]\d{2}[-/]\d{2}[\sT]\d{2}:\d{2}:\d{2}[^\]]*\]?\s*$")

DEFAULT_MAX_FAILURES = 10
DEFAULT_MAX_LINES = 15
OUTPUT_DIR = Path.home() / ".local" / "share" / "wrun"

# Framework internal paths to skip in stack traces
SKIP_FRAMES = {
    "site-packages",
    "_pytest",
    "pluggy",
    "node_modules",
    "_pydevd",
    "importlib",
    "unittest/",
    "asyncio/",
    "concurrent/futures",
    "threading.py",
}


# ─── Data Models ──────────────────────────────────────────────────────────────


@dataclass
class Config:
    max_failures: int = DEFAULT_MAX_FAILURES
    max_lines: int = DEFAULT_MAX_LINES
    full: bool = False
    json_output: bool = False
    quiet: bool = False
    no_save: bool = False
    stdin_mode: bool = False
    tool_hint: str = ""


@dataclass
class Failure:
    name: str
    file: str
    line: Optional[int] = None
    message: str = ""


@dataclass
class LintIssue:
    file: str
    line: int
    col: int = 0
    code: str = ""
    message: str = ""


@dataclass
class Result:
    tool: str
    exit_code: int
    duration: float
    total: int = 0
    passed: int = 0
    failed: int = 0
    skipped: int = 0
    errors: int = 0
    failures: list[Failure] = field(default_factory=list)
    lint_issues: list[LintIssue] = field(default_factory=list)
    raw_output_path: str = ""
    raw_line_count: int = 0
    raw_byte_count: int = 0
    extra: dict = field(default_factory=dict)


# ─── Utilities ────────────────────────────────────────────────────────────────


def strip_ansi(text: str) -> str:
    return ANSI_RE.sub("", text)


def get_git_root() -> Optional[Path]:
    try:
        r = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            timeout=3,
        )
        if r.returncode == 0:
            return Path(r.stdout.strip())
    except Exception:
        pass
    return None


def relativize_path(path_str: str, root: Path) -> str:
    """Convert an absolute path to relative, handling worktree roots.
    
    Keeps absolute paths for files outside the project root to avoid
    confusing ../../ traversals.
    """
    if not path_str:
        return path_str
    try:
        p = Path(path_str)
        if p.is_absolute():
            rel = p.relative_to(root)
            # Avoid ../../ paths - keep absolute if outside project
            rel_str = str(rel)
            if rel_str.startswith(".."):
                return path_str
            return rel_str
    except (ValueError, OSError):
        pass
    # For already-relative paths, check for excessive traversal
    if path_str.startswith("../../"):
        return str(Path(path_str).resolve())
    return path_str


def relativize_text(text: str, root: Optional[Path]) -> str:
    """Replace all occurrences of the git root path with relative paths."""
    if not root:
        root = Path.cwd()
    root_str = str(root)
    text = text.replace(root_str + os.sep, "")
    text = text.replace(root_str, ".")

    # Resolve ../../ traversals back to absolute for clarity
    def _resolve_traversal(m: re.Match) -> str:
        rel = m.group(0)
        try:
            resolved = str((root / rel).resolve())
            # Only replace if the resolved path exists and is shorter
            if len(resolved) < len(rel) or rel.count("../") >= 2:
                return resolved
        except (OSError, ValueError):
            pass
        return rel

    text = re.sub(r"(?:\.\./){2,}[^\s:]+", _resolve_traversal, text)
    return text


def is_framework_frame(line: str) -> bool:
    """Check if a stack trace line is from a framework internal."""
    return any(skip in line for skip in SKIP_FRAMES)


def truncate_stack_trace(lines: list[str], max_lines: int) -> list[str]:
    """Keep only user-relevant frames from a stack trace."""
    result = []
    skipped = 0
    for line in lines:
        if is_framework_frame(line):
            skipped += 1
            continue
        result.append(line)
        if len(result) >= max_lines:
            break

    if skipped > 0:
        result.append(f"  ... ({skipped} framework frames hidden)")
    return result


def remove_empty_and_decorative(lines: list[str]) -> list[str]:
    """Remove blank lines and decorative separators."""
    result = []
    for line in lines:
        stripped = line.strip()
        if not stripped:
            continue
        if DECORATIVE_RE.match(stripped):
            continue
        if PROGRESS_RE.match(stripped):
            continue
        if TIMESTAMP_ONLY_RE.match(stripped):
            continue
        result.append(line)
    return result


# ─── Tool Detection ──────────────────────────────────────────────────────────

TOOL_MAP = [
    ("pytest", ["pytest", "py.test", "python -m pytest"]),
    ("vitest", ["vitest"]),
    ("jest", ["jest"]),
    ("bun_test", ["bun test"]),
    ("ruff_check", ["ruff check"]),
    ("ruff_format", ["ruff format"]),
    ("biome", ["biome check", "biome lint", "biome ci"]),
    ("tsc", ["tsc", "npx tsc", "bunx tsc"]),
    ("mypy", ["mypy"]),
    ("ty", ["ty check"]),
]

# Standalone commands (checked via cmd_parts[0] for exact match)
SINGLE_CMD_MAP = {
    "grep": "grep",
    "egrep": "grep",
    "fgrep": "grep",
    "rg": "grep",
    "ag": "grep",
    "ls": "ls_tree",
    "ll": "ls_tree",
    "la": "ls_tree",
    "tree": "ls_tree",
}

# Git subcommand dispatch
GIT_SUBCOMMANDS = {
    "status": "git_status",
    "diff": "git_diff",
    "log": "git_log",
    "show": "git_log",
    "add": "git_write",
    "commit": "git_write",
    "push": "git_write",
    "pull": "git_write",
    "fetch": "git_write",
    "rm": "git_write",
    "mv": "git_write",
    "checkout": "git_write",
    "switch": "git_write",
    "merge": "git_write",
    "rebase": "git_write",
    "stash": "git_write",
}

# Docker subcommand dispatch
DOCKER_SUBCOMMANDS = {
    "ps": "docker_ps",
    "images": "docker_ps",
    "image": "docker_ps",
    "container": "docker_ps",
}


def detect_tool(cmd_parts: list[str]) -> str:
    if not cmd_parts:
        return "generic"

    cmd0 = Path(cmd_parts[0]).name.lower()

    # Single-word commands (grep, rg, ls, tree, ...)
    if cmd0 in SINGLE_CMD_MAP:
        return SINGLE_CMD_MAP[cmd0]

    # Git subcommands (skip global flags like `-c k=v`, `-C path`, `--git-dir=...`)
    if cmd0 == "git" and len(cmd_parts) > 1:
        idx = 1
        while idx < len(cmd_parts):
            arg = cmd_parts[idx]
            if arg in ("-c", "-C"):
                idx += 2  # skip flag + value
                continue
            if arg.startswith("--git-dir") or arg.startswith("--work-tree") or arg.startswith("--namespace"):
                idx += 1
                continue
            break
        if idx < len(cmd_parts):
            sub = cmd_parts[idx].lower()
            if sub in GIT_SUBCOMMANDS:
                return GIT_SUBCOMMANDS[sub]

    # Docker subcommands
    if cmd0 == "docker" and len(cmd_parts) > 1:
        sub = cmd_parts[1].lower()
        if sub in DOCKER_SUBCOMMANDS:
            # Disambiguate: `docker container ls`, `docker image ls`
            if sub in ("container", "image") and len(cmd_parts) > 2 and cmd_parts[2].lower() in ("ls", "list"):
                return "docker_ps"
            if sub == "ps" or sub == "images":
                return "docker_ps"

    # Fallback: TOOL_MAP substring matching for test runners and linters
    cmd_str = " ".join(cmd_parts).lower()
    for prefix in ["uv run ", "bun run ", "bunx ", "npx ", "pnpm exec ", "yarn ", "python -m "]:
        cmd_str_check = cmd_str.replace(prefix, "")
        for tool, patterns in TOOL_MAP:
            for pattern in patterns:
                if pattern in cmd_str_check or pattern in cmd_str:
                    return tool
    for tool, patterns in TOOL_MAP:
        for pattern in patterns:
            if pattern in cmd_str:
                return tool
    return "generic"


def detect_tool_from_output(output: str) -> str:
    """Fallback: detect tool from output patterns when command detection fails."""
    # Check first and last 30 lines for known patterns
    lines = output.splitlines()
    sample = "\n".join(lines[:30] + lines[-30:])

    if "pytest" in sample or "test session starts" in sample or "short test summary info" in sample:
        return "pytest"
    if "FAIL " in sample and ("Tests " in sample or "Test Suites" in sample):
        return "vitest"  # covers vitest/jest/bun
    if re.search(r"\S+:\d+:\d+:\s+[A-Z]\d+\s+", sample):
        return "ruff_check"
    if "error TS" in sample:
        return "tsc"
    if re.search(r"Found \d+ error", sample):
        # Could be ruff, tsc, or biome - check more
        if "TS" in sample:
            return "tsc"
        return "ruff_check"
    return "generic"


# ─── Parsers ──────────────────────────────────────────────────────────────────


class Parser(ABC):
    @abstractmethod
    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        ...


class PytestParser(Parser):
    """Parser for pytest output."""

    SUMMARY_RE = re.compile(
        r"(?:=+\s+)?"
        r"(?:(?P<failed>\d+)\s+failed)?"
        r"[,\s]*"
        r"(?:(?P<passed>\d+)\s+passed)?"
        r"[,\s]*"
        r"(?:(?P<skipped>\d+)\s+(?:skipped|deselected))?"
        r"[,\s]*"
        r"(?:(?P<error>\d+)\s+error)?"
        r"[,\s]*"
        r"(?:(?P<warning>\d+)\s+warning)?"
        # `\s*in\s+` — use `*` on left so the preceding `[,\s]*` doesn't eat the space `in` needs
        r"(?:\s*in\s+(?P<duration>[\d.]+)s)?"
    )

    SHORT_SUMMARY_RE = re.compile(
        r"^(?:FAILED|ERROR)\s+(?P<file>[^\s:]+)::(?P<test>[^\s]+)"
        r"(?:\s*-\s*(?P<message>.+))?$"
    )

    LOCATION_RE = re.compile(r"(\S+\.py):(\d+):")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        lines = output.splitlines()
        result = Result(tool="pytest", exit_code=0, duration=0)

        # Parse summary line (last meaningful line)
        for line in reversed(lines):
            m = self.SUMMARY_RE.search(line)
            if m and any(m.group(g) for g in ["failed", "passed", "skipped", "error"]):
                result.failed = int(m.group("failed") or 0)
                result.passed = int(m.group("passed") or 0)
                result.skipped = int(m.group("skipped") or 0)
                result.errors = int(m.group("error") or 0)
                result.total = result.passed + result.failed + result.skipped + result.errors
                if m.group("duration"):
                    result.duration = float(m.group("duration"))
                break

        # Step 1: Extract line numbers + assertion details + full error messages from FAILURES section
        # NOTE: FAILURES uses "." separator (TestAuth.test_login) while short summary uses "::"
        #       We normalize all keys to "::" format for consistent lookup
        line_map: dict[str, int] = {}  # normalized_name -> line_number
        assert_map: dict[str, str] = {}  # normalized_name -> assertion detail
        error_map: dict[str, str] = {}  # normalized_name -> full error message (first E line)
        in_failures = False
        current_test = ""
        current_test_key = ""
        for line in lines:
            if "FAILURES" in line and line.strip().startswith("="):
                in_failures = True
                continue
            if not in_failures:
                continue
            if line.strip().startswith("=") and ("passed" in line or "error" in line or "warning" in line):
                break
            if line.strip().startswith("_") and line.strip().endswith("_"):
                current_test = line.strip().strip("_ ")
                # Normalize: "TestAuth.test_login" -> "TestAuth::test_login"
                current_test_key = current_test.replace(".", "::")
                continue
            if current_test_key:
                loc = self.LOCATION_RE.search(line)
                if loc and current_test_key not in line_map:
                    line_map[current_test_key] = int(loc.group(2))
                # Extract E-lines (assertion details + full error)
                stripped = line.strip()
                if stripped.startswith("E "):
                    detail = stripped[2:].strip()
                    if detail.startswith("assert ") or detail.startswith("where "):
                        assert_map[current_test_key] = detail
                    elif current_test_key not in error_map:
                        error_map[current_test_key] = detail

        # Step 2: Parse short test summary, enrich with FAILURES data
        in_short_summary = False
        current_failure: Optional[Failure] = None
        for line in lines:
            if "short test summary info" in line:
                in_short_summary = True
                continue
            if not in_short_summary:
                continue
            if line.startswith("="):
                break

            m = self.SHORT_SUMMARY_RE.match(line.strip())
            if m:
                if current_failure:
                    result.failures.append(current_failure)

                file_path = relativize_path(m.group("file"), git_root) if git_root else m.group("file")
                test_name = m.group("test")
                line_num = line_map.get(test_name)

                # Build message: prefer FAILURES section data over truncated short summary
                short_msg = (m.group("message") or "").strip()
                full_error = error_map.get(test_name, "")
                assertion = assert_map.get(test_name, "")

                # If short summary is truncated (ends with ...), use full error from FAILURES
                if short_msg.endswith("...") and full_error:
                    msg = full_error
                else:
                    msg = short_msg

                # Append assertion detail (actual vs expected)
                if assertion and assertion not in msg:
                    msg = f"{msg} | {assertion}" if msg else assertion

                current_failure = Failure(
                    name=test_name,
                    file=file_path,
                    line=line_num,
                    message=msg,
                )
            elif current_failure and line.strip():
                cont = line.strip()
                if cont.startswith("+"):
                    cont = cont.lstrip("+ ")
                if current_failure.message:
                    current_failure.message += " | " + cont
                else:
                    current_failure.message = cont

        if current_failure:
            result.failures.append(current_failure)

        # Fallback: parse FAILURES section if no short summary
        if not result.failures and result.failed > 0:
            self._parse_failures_section(lines, result, git_root, config)

        return result

    def _parse_failures_section(
        self, lines: list[str], result: Result, git_root: Optional[Path], config: Config
    ) -> None:
        in_failures = False
        current_name = ""
        current_lines: list[str] = []
        current_file = ""

        for line in lines:
            if "FAILURES" in line and line.strip().startswith("="):
                in_failures = True
                continue
            if not in_failures:
                continue
            if line.strip().startswith("=") and "passed" in line:
                break

            # New test failure header
            if line.strip().startswith("_") and line.strip().endswith("_"):
                if current_name:
                    self._add_failure(result, current_name, current_file, current_lines, git_root, config)
                current_name = line.strip().strip("_ ")
                current_lines = []
                current_file = ""
                continue

            if current_name:
                # Capture file reference
                file_match = re.search(r"(\S+\.py):(\d+)", line)
                if file_match and not current_file:
                    current_file = file_match.group(1)

                current_lines.append(line)

        if current_name:
            self._add_failure(result, current_name, current_file, current_lines, git_root, config)

    def _add_failure(
        self,
        result: Result,
        name: str,
        file: str,
        raw_lines: list[str],
        git_root: Optional[Path],
        config: Config,
    ) -> None:
        filtered = truncate_stack_trace(raw_lines, config.max_lines)
        filtered = remove_empty_and_decorative(filtered)
        message = "\n".join(filtered[:config.max_lines])
        if git_root and file:
            file = relativize_path(file, git_root)
        result.failures.append(Failure(name=name, file=file, message=message))


class VitestBunParser(Parser):
    """Parser for vitest, jest, and bun test output."""

    SUMMARY_RE = re.compile(
        r"Tests?\s+"
        r"(?:(?P<failed>\d+)\s+failed\s*\|?\s*)?"
        r"(?:(?P<passed>\d+)\s+passed\s*\|?\s*)?"
        r"(?:(?P<skipped>\d+)\s+(?:skipped|todo)\s*\|?\s*)?"
        r"\(?(?P<total>\d+)\)?"
    )

    DURATION_RE = re.compile(r"(?:Duration|Time)\s+([\d.]+)\s*([ms]+)")

    FAIL_HEADER_RE = re.compile(
        r"(?:FAIL|×|✕|✗)\s+(?P<file>\S+)"
        r"(?:\s*>\s*(?P<suite>.+?))?"
        r"(?:\s*>\s*(?P<test>.+))?"
    )

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        lines = output.splitlines()
        result = Result(tool="vitest", exit_code=0, duration=0)

        # Parse summary
        for line in reversed(lines):
            m = self.SUMMARY_RE.search(line)
            if m and m.group("total"):
                result.total = int(m.group("total"))
                result.passed = int(m.group("passed") or 0)
                result.failed = int(m.group("failed") or 0)
                result.skipped = int(m.group("skipped") or 0)
                break

        # Parse duration
        for line in reversed(lines):
            m = self.DURATION_RE.search(line)
            if m:
                val = float(m.group(1))
                unit = m.group(2)
                result.duration = val / 1000 if unit == "ms" else val
                break

        # Parse failures
        self._parse_fail_blocks(lines, result, git_root, config)

        return result

    def _parse_fail_blocks(
        self, lines: list[str], result: Result, git_root: Optional[Path], config: Config
    ) -> None:
        i = 0
        while i < len(lines):
            line = lines[i].strip()
            m = self.FAIL_HEADER_RE.match(line)
            if m:
                file_path = m.group("file")
                test_name = m.group("test") or m.group("suite") or "unknown"
                if git_root:
                    file_path = relativize_path(file_path, git_root)

                # Collect error message lines
                msg_lines = []
                i += 1
                while i < len(lines):
                    next_line = lines[i]
                    next_stripped = next_line.strip()
                    if not next_stripped:
                        i += 1
                        continue
                    if self.FAIL_HEADER_RE.match(next_stripped):
                        break
                    if next_stripped.startswith(("Tests ", "Test Suites", "Duration", "Time")):
                        break
                    if re.match(r"^[─⎯\-]{3,}", next_stripped):
                        i += 1
                        continue
                    msg_lines.append(next_line)
                    i += 1

                filtered = truncate_stack_trace(msg_lines, config.max_lines)
                filtered = remove_empty_and_decorative(filtered)
                message = "\n".join(filtered[:config.max_lines]).strip()

                # Extract line number from message
                line_num = None
                loc_match = re.search(r"(\S+):(\d+):\d+", message)
                if loc_match:
                    line_num = int(loc_match.group(2))

                result.failures.append(
                    Failure(name=test_name, file=file_path, line=line_num, message=message)
                )
                continue
            i += 1


class RuffParser(Parser):
    """Parser for ruff check output (supports both classic and modern format)."""

    # Classic: file:line:col: CODE message
    CLASSIC_RE = re.compile(r"^(?P<file>\S+):(?P<line>\d+):(?P<col>\d+):\s+(?P<code>\S+)\s+(?P<msg>.+)$")
    # Modern (ruff 0.4+): CODE [*] message — ruff rules are 1-3 letters + 3-4 digits
    MODERN_RULE_RE = re.compile(r"^(?P<code>[A-Z]{1,3}\d{3,4})\s+(?:\[\*\]\s+)?(?P<msg>.+)$")
    # Modern location: --> file:line:col
    MODERN_LOC_RE = re.compile(r"^\s*-->\s*(?P<file>\S+):(?P<line>\d+):(?P<col>\d+)")
    SUMMARY_RE = re.compile(r"Found\s+(?P<count>\d+)\s+error")
    FIXABLE_RE = re.compile(r"\[?\*?\]?\s*(?P<fixable>\d+)\s+fixable")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        lines = output.splitlines()
        result = Result(tool="ruff", exit_code=0, duration=0)
        issues: list[LintIssue] = []

        i = 0
        while i < len(lines):
            line = lines[i].strip()

            # Try classic format first
            m = self.CLASSIC_RE.match(line)
            if m:
                file_path = m.group("file")
                if git_root:
                    file_path = relativize_path(file_path, git_root)
                issues.append(
                    LintIssue(
                        file=file_path,
                        line=int(m.group("line")),
                        col=int(m.group("col")),
                        code=m.group("code"),
                        message=m.group("msg").strip(),
                    )
                )
                i += 1
                continue

            # Try modern format: CODE [*] message, then --> file:line:col
            rm = self.MODERN_RULE_RE.match(line)
            if rm:
                code = rm.group("code")
                msg = rm.group("msg").strip()
                # Look ahead for --> location
                file_path = ""
                line_num = 0
                col_num = 0
                for j in range(i + 1, min(i + 4, len(lines))):
                    lm = self.MODERN_LOC_RE.match(lines[j])
                    if lm:
                        file_path = lm.group("file")
                        if git_root:
                            file_path = relativize_path(file_path, git_root)
                        line_num = int(lm.group("line"))
                        col_num = int(lm.group("col"))
                        break
                if file_path:
                    issues.append(
                        LintIssue(file=file_path, line=line_num, col=col_num, code=code, message=msg)
                    )

            sm = self.SUMMARY_RE.search(line)
            if sm:
                result.errors = int(sm.group("count"))

            fm = self.FIXABLE_RE.search(line)
            if fm:
                result.extra["fixable"] = int(fm.group("fixable"))

            i += 1

        result.lint_issues = issues
        result.total = len(issues)
        result.failed = result.errors or len(issues)
        return result


class BiomeParser(Parser):
    """Parser for biome check/lint output."""

    DIAG_RE = re.compile(
        r"(?P<file>\S+):(?P<line>\d+):(?P<col>\d+)\s+"
        r"(?P<level>error|warning|info)\s+"
        r"(?P<code>\S+)\s+"
        r"(?P<msg>.+)"
    )
    SIMPLE_RE = re.compile(r"^(?P<file>\S+)\s+(?P<code>[a-zA-Z]+/\S+)\s+.*$")
    SUMMARY_RE = re.compile(r"(?:Found\s+)?(?P<errors>\d+)\s+error|(?P<warns>\d+)\s+warning")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        lines = output.splitlines()
        result = Result(tool="biome", exit_code=0, duration=0)
        issues: list[LintIssue] = []

        for line in lines:
            line_stripped = line.strip()
            m = self.DIAG_RE.match(line_stripped)
            if not m:
                m = self.SIMPLE_RE.match(line_stripped)
            if m:
                file_path = m.group("file")
                if git_root:
                    file_path = relativize_path(file_path, git_root)
                issues.append(
                    LintIssue(
                        file=file_path,
                        line=int(m.group("line")) if "line" in m.groupdict() and m.group("line") else 0,
                        col=int(m.group("col")) if "col" in m.groupdict() and m.group("col") else 0,
                        code=m.group("code"),
                        message=m.group("msg").strip() if "msg" in m.groupdict() and m.group("msg") else "",
                    )
                )

            sm = self.SUMMARY_RE.search(line)
            if sm:
                if sm.group("errors"):
                    result.errors = int(sm.group("errors"))

        result.lint_issues = issues
        result.total = len(issues)
        result.failed = result.errors or len(issues)
        return result


class TscParser(Parser):
    """Parser for TypeScript compiler output."""

    ERROR_RE = re.compile(
        r"^(?P<file>\S+)\((?P<line>\d+),(?P<col>\d+)\):\s+error\s+(?P<code>TS\d+):\s+(?P<msg>.+)$"
    )
    ALT_ERROR_RE = re.compile(
        r"^(?P<file>\S+):(?P<line>\d+):(?P<col>\d+)\s+-\s+error\s+(?P<code>TS\d+):\s+(?P<msg>.+)$"
    )
    SUMMARY_RE = re.compile(r"Found\s+(?P<count>\d+)\s+error")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        lines = output.splitlines()
        result = Result(tool="tsc", exit_code=0, duration=0)
        issues: list[LintIssue] = []

        for line in lines:
            line_stripped = line.strip()
            m = self.ERROR_RE.match(line_stripped) or self.ALT_ERROR_RE.match(line_stripped)
            if m:
                file_path = m.group("file")
                if git_root:
                    file_path = relativize_path(file_path, git_root)
                issues.append(
                    LintIssue(
                        file=file_path,
                        line=int(m.group("line")),
                        col=int(m.group("col")),
                        code=m.group("code"),
                        message=m.group("msg").strip(),
                    )
                )

            sm = self.SUMMARY_RE.search(line)
            if sm:
                result.errors = int(sm.group("count"))

        result.lint_issues = issues
        result.total = len(issues)
        result.failed = result.errors or len(issues)
        return result


class GitStatusParser(Parser):
    """Parse `git status` and `git status --porcelain`.

    Outputs a compact porcelain-like summary: `XY path` per entry,
    where X=index status, Y=worktree status. Groups counts by type.
    """

    BRANCH_RE = re.compile(r"^On branch (\S+)")
    HEAD_RE = re.compile(r"^HEAD detached at (\S+)")
    PORCELAIN_RE = re.compile(r"^([ MADRCU?!])([ MADRCU?!]) (.+)$")

    REGULAR_STATUS_MAP = {
        "modified:": " M",
        "new file:": "A ",
        "deleted:": " D",
        "renamed:": "R ",
        "copied:": "C ",
        "typechange:": "T ",
        "both modified:": "UU",
        "both added:": "AA",
        "both deleted:": "DD",
    }

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="git_status", exit_code=0, duration=0)
        lines = output.splitlines()
        entries: list[tuple[str, str]] = []
        branch = ""
        is_porcelain = True
        untracked_section = False

        for raw in lines:
            if not raw.strip():
                continue
            # Regular format markers
            m_branch = self.BRANCH_RE.match(raw)
            if m_branch:
                branch = m_branch.group(1)
                is_porcelain = False
                continue
            m_head = self.HEAD_RE.match(raw)
            if m_head:
                branch = f"HEAD@{m_head.group(1)}"
                is_porcelain = False
                continue

            # Porcelain format
            m_porcelain = self.PORCELAIN_RE.match(raw)
            if m_porcelain and is_porcelain:
                xy = m_porcelain.group(1) + m_porcelain.group(2)
                path = m_porcelain.group(3)
                entries.append((xy, path))
                continue

            # Regular (human) format
            if is_porcelain is False:
                stripped = raw.strip()
                if stripped.startswith("Untracked files:"):
                    untracked_section = True
                    continue
                if stripped.startswith(("Changes ", "Unmerged ", "no changes ", "nothing to commit", "Your branch")):
                    untracked_section = False
                    continue
                if stripped.startswith("(") or stripped.startswith("#"):
                    continue
                # Untracked entries
                if untracked_section and not stripped.endswith(":"):
                    entries.append(("??", stripped))
                    continue
                # Modified/new file/deleted/renamed
                for prefix, code in self.REGULAR_STATUS_MAP.items():
                    if stripped.startswith(prefix):
                        path = stripped[len(prefix):].strip()
                        entries.append((code, path))
                        break

        # Count by type
        counts: dict[str, int] = {}
        for xy, _ in entries:
            key = xy.strip() or "?"
            counts[key] = counts.get(key, 0) + 1

        result.total = len(entries)
        result.extra["git_branch"] = branch
        result.extra["git_status_entries"] = entries
        result.extra["git_status_counts"] = counts
        return result


class GitDiffParser(Parser):
    """Parse `git diff` output. Extracts file stats without hunk bodies."""

    FILE_RE = re.compile(r"^diff --git a/(\S+) b/(\S+)")
    NEW_FILE_RE = re.compile(r"^new file mode")
    DEL_FILE_RE = re.compile(r"^deleted file mode")
    STAT_RE = re.compile(r"^\s*(\S+)\s*\|\s*(\d+|Bin)\s*([+\-]*)\s*$")
    STAT_SUMMARY_RE = re.compile(
        r"(\d+)\s+files?\s+changed"
        r"(?:,\s+(\d+)\s+insertions?\(\+\))?"
        r"(?:,\s+(\d+)\s+deletions?\(-\))?"
    )

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="git_diff", exit_code=0, duration=0)
        lines = output.splitlines()

        # Track per-file stats while scanning real diff
        file_stats: dict[str, dict[str, int]] = {}
        current_file: Optional[str] = None
        stat_rows: list[tuple[str, str]] = []  # (path, marker)
        summary_files = 0
        summary_add = 0
        summary_del = 0

        for raw in lines:
            # --stat style: `path | N +++---`
            m_stat = self.STAT_RE.match(raw)
            if m_stat and "|" in raw:
                stat_rows.append((m_stat.group(1), raw.strip()))
                continue

            # Summary line `N files changed, X insertions(+), Y deletions(-)`
            m_sum = self.STAT_SUMMARY_RE.search(raw)
            if m_sum and raw.strip().endswith(("(+)", "(-)", "changed")):
                summary_files = int(m_sum.group(1))
                summary_add = int(m_sum.group(2) or 0)
                summary_del = int(m_sum.group(3) or 0)
                continue

            # File header
            m_file = self.FILE_RE.match(raw)
            if m_file:
                current_file = m_file.group(2)
                file_stats.setdefault(current_file, {"add": 0, "del": 0, "status": "M"})
                continue

            if current_file:
                if self.NEW_FILE_RE.match(raw):
                    file_stats[current_file]["status"] = "A"
                    continue
                if self.DEL_FILE_RE.match(raw):
                    file_stats[current_file]["status"] = "D"
                    continue
                # Count diff lines (skip hunk/file headers)
                if raw.startswith("+") and not raw.startswith("+++"):
                    file_stats[current_file]["add"] += 1
                elif raw.startswith("-") and not raw.startswith("---"):
                    file_stats[current_file]["del"] += 1

        if file_stats:
            total_add = sum(v["add"] for v in file_stats.values())
            total_del = sum(v["del"] for v in file_stats.values())
            result.extra["git_diff_files"] = [
                (path, v["status"], v["add"], v["del"])
                for path, v in file_stats.items()
            ]
            result.extra["git_diff_totals"] = (len(file_stats), total_add, total_del)
        elif stat_rows:
            result.extra["git_diff_stat_rows"] = stat_rows
            result.extra["git_diff_totals"] = (summary_files or len(stat_rows), summary_add, summary_del)
        else:
            result.extra["git_diff_totals"] = (0, 0, 0)

        result.total = result.extra["git_diff_totals"][0]
        return result


class GitLogParser(Parser):
    """Parse `git log` output. Extracts one line per commit (hash + subject)."""

    COMMIT_RE = re.compile(r"^commit ([0-9a-f]{7,40})")
    # Accepts optional `--graph` prefix chars (*, |, /, \, _, space) before the hash
    ONELINE_RE = re.compile(r"^[\s*|/\\_]*([0-9a-f]{7,40})\s+(.+)$")
    SUBJECT_INDENT_RE = re.compile(r"^ {4}(\S.*)$")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="git_log", exit_code=0, duration=0)
        lines = output.splitlines()
        entries: list[tuple[str, str]] = []

        current_hash = ""
        current_subject = ""
        full_format = False

        for raw in lines:
            m_commit = self.COMMIT_RE.match(raw)
            if m_commit:
                full_format = True
                if current_hash and current_subject:
                    entries.append((current_hash, current_subject))
                current_hash = m_commit.group(1)[:7]
                current_subject = ""
                continue

            if full_format:
                m_subject = self.SUBJECT_INDENT_RE.match(raw)
                if m_subject and not current_subject:
                    current_subject = m_subject.group(1).strip()
                continue

            # Oneline format
            m_oneline = self.ONELINE_RE.match(raw)
            if m_oneline:
                h = m_oneline.group(1)[:7]
                entries.append((h, m_oneline.group(2).strip()))

        if full_format and current_hash and current_subject:
            entries.append((current_hash, current_subject))

        result.total = len(entries)
        result.extra["git_log_entries"] = entries
        return result


class GitWriteParser(Parser):
    """Parse mutating git commands (add/commit/push/pull/fetch/...).

    Produces a 1-line summary — never needs more.
    """

    COMMIT_HASH_RE = re.compile(r"^\[(\S+)\s+(?:\(root-commit\)\s+)?([0-9a-f]{7,40})\]\s+(.+)$")
    COMMIT_CHANGE_RE = re.compile(r"^\s*(\d+)\s+files?\s+changed")
    PUSH_SUMMARY_RE = re.compile(r"^\s*([0-9a-f]+)\.\.([0-9a-f]+)\s+(\S+)\s+->\s+(\S+)")
    PULL_UPDATING_RE = re.compile(r"^Updating\s+([0-9a-f]+)\.\.([0-9a-f]+)")
    FAST_FORWARD_RE = re.compile(r"^Fast-forward")
    ALREADY_UP_RE = re.compile(r"^Already up to date")
    NOTHING_COMMIT_RE = re.compile(r"^nothing to commit")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="git_write", exit_code=0, duration=0)
        lines = output.splitlines()
        summary = ""
        files_changed = 0

        for raw in lines:
            m_commit = self.COMMIT_HASH_RE.match(raw)
            if m_commit:
                branch = m_commit.group(1)
                sha = m_commit.group(2)[:7]
                msg = m_commit.group(3)
                summary = f"commit {sha} on {branch}: {msg}"
                continue

            m_change = self.COMMIT_CHANGE_RE.match(raw)
            if m_change:
                files_changed = int(m_change.group(1))
                continue

            m_push = self.PUSH_SUMMARY_RE.match(raw)
            if m_push:
                summary = f"pushed {m_push.group(1)[:7]}..{m_push.group(2)[:7]} {m_push.group(3)} -> {m_push.group(4)}"
                continue

            m_pull = self.PULL_UPDATING_RE.match(raw)
            if m_pull:
                summary = f"updating {m_pull.group(1)[:7]}..{m_pull.group(2)[:7]}"
                continue

            if self.ALREADY_UP_RE.match(raw):
                summary = "already up to date"
                continue

            if self.NOTHING_COMMIT_RE.match(raw):
                summary = "nothing to commit"
                continue

        if files_changed and summary.startswith("commit"):
            summary += f" ({files_changed} files)"

        if not summary:
            # Fallback: first non-blank line
            for raw in lines:
                if raw.strip():
                    summary = raw.strip()[:180]
                    break

        result.extra["git_write_summary"] = summary or "done"
        return result


class DockerPsParser(Parser):
    """Parse `docker ps` / `docker images` output.

    Splits columns on 2+ spaces. Tolerant to variable column widths — does not
    depend on header alignment matching data alignment (which breaks when values
    are wider than the header column).
    """

    # Header column names split the same way: by 2+ whitespace
    MULTI_SPACE_RE = re.compile(r"\s{2,}")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="docker_ps", exit_code=0, duration=0)
        lines = [l for l in output.splitlines() if l.strip()]
        if not lines:
            result.extra["docker_rows"] = []
            result.extra["docker_kind"] = "ps"
            return result

        header = lines[0]
        col_names = self._split_cols(header)
        kind = "images" if any(n == "REPOSITORY" for n in col_names) else "ps"

        rows: list[dict[str, str]] = []
        for line in lines[1:]:
            values = self._split_cols(line)
            # Pad or truncate to match header arity
            if len(values) < len(col_names):
                values = values + [""] * (len(col_names) - len(values))
            elif len(values) > len(col_names):
                # Collapse trailing excess into last column (rare edge)
                values = values[: len(col_names) - 1] + [
                    "  ".join(values[len(col_names) - 1 :])
                ]
            rows.append(dict(zip(col_names, values)))

        running = 0
        stopped = 0
        for row in rows:
            status = row.get("STATUS", "")
            if status.startswith("Up"):
                running += 1
            elif status.startswith(("Exited", "Created", "Dead", "Restarting")):
                stopped += 1

        result.total = len(rows)
        result.extra["docker_rows"] = rows
        result.extra["docker_kind"] = kind
        result.extra["docker_running"] = running
        result.extra["docker_stopped"] = stopped
        return result

    @classmethod
    def _split_cols(cls, line: str) -> list[str]:
        return [c for c in cls.MULTI_SPACE_RE.split(line.strip()) if c]


class GrepRgParser(Parser):
    """Parse grep/rg/ag output. Groups matches by file, caps per-file and total."""

    # file:line:content (grep -n, rg default)
    FILE_LINE_RE = re.compile(r"^([^:\x00]+?):(\d+):(.*)$")
    # file-line-content (grep -C context lines)
    FILE_LINE_DASH_RE = re.compile(r"^([^:\x00]+?)-(\d+)-(.*)$")
    # line:content only (single-file grep without -H)
    LINE_ONLY_RE = re.compile(r"^(\d+):(.*)$")
    # rg --count format: file:count
    COUNT_RE = re.compile(r"^([^:\x00]+?):(\d+)$")

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="grep", exit_code=0, duration=0)
        lines = output.splitlines()
        by_file: dict[str, list[tuple[int, str]]] = {}
        unmatched: list[str] = []

        for raw in lines:
            if not raw.strip():
                continue
            # Try file:line:content first (most common: grep -rn, rg default)
            m = self.FILE_LINE_RE.match(raw)
            if m and not m.group(1).isdigit():
                path = m.group(1)
                # Reject if path contains impossible chars (likely a content line)
                if "\t" not in path:
                    lineno = int(m.group(2))
                    content = m.group(3)
                    by_file.setdefault(path, []).append((lineno, content))
                    continue

            # line:content only (single file without -H or stdin)
            m_line = self.LINE_ONLY_RE.match(raw)
            if m_line:
                lineno = int(m_line.group(1))
                content = m_line.group(2)
                by_file.setdefault("(stdin)", []).append((lineno, content))
                continue

            m_dash = self.FILE_LINE_DASH_RE.match(raw)
            if m_dash and not m_dash.group(1).isdigit():
                path = m_dash.group(1)
                lineno = int(m_dash.group(2))
                by_file.setdefault(path, []).append((lineno, m_dash.group(3)))
                continue

            # Fallback: file:content (rg/grep with --no-line-number)
            if ":" in raw:
                path, _, content = raw.partition(":")
                looks_like_path = (
                    path
                    and not path.isdigit()
                    and "/" in path
                    or path.endswith((
                        ".py", ".ts", ".tsx", ".js", ".jsx", ".go", ".rs",
                        ".java", ".rb", ".c", ".cpp", ".h", ".md", ".txt",
                        ".yml", ".yaml", ".json", ".toml", ".lock", ".html",
                        ".css", ".scss", ".vue", ".svelte", ".sh", ".zsh",
                    ))
                )
                if looks_like_path:
                    by_file.setdefault(path, []).append((0, content))
                    continue

            unmatched.append(raw)

        # If nothing structured matched but we have unmatched content (rg single-file
        # without -H), treat unmatched as anonymous-file matches.
        if not by_file and unmatched:
            anon_matches = [(i + 1, line) for i, line in enumerate(unmatched)]
            by_file["(match)"] = anon_matches
            unmatched = []

        total_matches = sum(len(v) for v in by_file.values())
        result.total = total_matches
        result.extra["grep_by_file"] = by_file
        result.extra["grep_total"] = total_matches
        result.extra["grep_unmatched"] = unmatched[: config.max_lines]
        return result


class LsTreeParser(Parser):
    """Parse `ls -l` / `ls -la` / `tree` output. Strips noise, caps entries."""

    # `ls -l`: perms links owner group size date time name
    LS_LONG_RE = re.compile(
        r"^([dlcbps\-])([rwx\-stST]{9}[@+]?)\s+\d+\s+\S+\s+\S+\s+"
        r"(\S+)\s+"  # size
        r"(\S+\s+\S+\s+\S+)\s+"  # date time
        r"(.+)$"
    )
    # `tree` output has prefix chars ├── │   └──
    TREE_PREFIX_RE = re.compile(r"^([│├└─\s]+)(.*)$")
    NOISE_DIRS = {
        "node_modules", ".git", "__pycache__", ".venv", "venv",
        ".mypy_cache", ".pytest_cache", ".ruff_cache", "dist",
        "build", ".next", ".nuxt", "target", ".idea", ".vscode",
    }

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="ls_tree", exit_code=0, duration=0)
        lines = output.splitlines()
        entries: list[tuple[str, str]] = []  # (kind, display)
        hidden = 0
        is_tree = any(self.TREE_PREFIX_RE.match(l) and ("├" in l or "└" in l) for l in lines[:20])

        if is_tree:
            # tree output ends with line like "2 directories, 5 files" — skip it
            tree_summary_re = re.compile(r"^\d+\s+director(?:y|ies),\s+\d+\s+files?$")
            skip_indent: Optional[int] = None
            for raw in lines:
                stripped = raw.strip()
                if not stripped:
                    continue
                if tree_summary_re.match(stripped):
                    continue
                m = self.TREE_PREFIX_RE.match(raw)
                if not m:
                    entries.append(("", raw))
                    skip_indent = None
                    continue
                prefix = m.group(1)
                indent = len(prefix)
                name = m.group(2).strip()
                if not name:
                    continue
                # Skip descendants of a previously hidden noise dir
                if skip_indent is not None and indent > skip_indent:
                    hidden += 1
                    continue
                skip_indent = None
                noise_hit = name.split()[0] if name else ""
                if noise_hit in self.NOISE_DIRS or any(
                    name == n or name.startswith(n + "/") for n in self.NOISE_DIRS
                ):
                    hidden += 1
                    skip_indent = indent
                    continue
                entries.append(("", prefix + name))
        else:
            for raw in lines:
                stripped = raw.strip()
                if not stripped or stripped.startswith("total "):
                    continue
                m_long = self.LS_LONG_RE.match(stripped)
                if m_long:
                    type_char = m_long.group(1)
                    size = m_long.group(3)
                    name = m_long.group(5)
                    kind = {"d": "D", "l": "L"}.get(type_char, "F")
                    name_head = name.split(" -> ")[0].strip()
                    if name_head in self.NOISE_DIRS or name_head in (".", ".."):
                        hidden += 1
                        continue
                    entries.append((kind, f"{kind} {size:>8} {name}"))
                else:
                    for tok in raw.split():
                        if tok in self.NOISE_DIRS or tok in (".", ".."):
                            hidden += 1
                            continue
                        entries.append(("", tok))

        result.total = len(entries)
        result.extra["ls_entries"] = entries
        result.extra["ls_hidden"] = hidden
        result.extra["ls_is_tree"] = is_tree
        return result


class GenericParser(Parser):
    """Smart fallback: extract error-relevant lines instead of blind head+tail."""

    ERROR_PATTERNS = re.compile(
        r"(?i)^.*("
        r"error[\s:\[]|ERROR[\s:\[]|"
        r"FAIL(?:ED|URE)?[\s:\[]|"
        r"fatal[\s:\[]|FATAL[\s:\[]|"
        r"panic[\s:\[]|"
        r"Traceback \(most recent|"
        r"Exception[\s:]|"
        r"cannot find|Could not|No such file|Permission denied|"
        r"command not found|"
        r"segmentation fault|core dumped|"
        r"BUILD FAIL|compilation fail|"
        r"SyntaxError|TypeError|ValueError|KeyError|"
        r"ImportError|ModuleNotFoundError|"
        r"warning[\s:\[]"
        r").*$",
        re.MULTILINE,
    )

    def parse(self, output: str, git_root: Optional[Path], config: Config) -> Result:
        result = Result(tool="generic", exit_code=0, duration=0)
        # Store error-extracted lines for the formatter
        lines = output.splitlines()
        error_lines: list[str] = []
        seen_indices: set[int] = set()

        for m in self.ERROR_PATTERNS.finditer(output):
            # Find line index
            line_start = output.count("\n", 0, m.start())
            # Get context: 1 line before + error + 2 lines after
            for idx in range(max(0, line_start - 1), min(len(lines), line_start + 3)):
                if idx not in seen_indices:
                    seen_indices.add(idx)
                    error_lines.append(lines[idx])
            if len(error_lines) >= config.max_lines * 2:
                break

        result.extra["error_lines"] = error_lines
        result.extra["total_lines"] = len(lines)
        return result


