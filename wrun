#!/usr/bin/env python3
"""wrun - Bash Wrapper: Optimized command output for AI consumption.

Wraps any bash command, captures output, and produces a minimal
token-efficient summary. Designed for test runners, linters, type
checkers, and build tools.

Usage:
    wrun <command> [args...]
    wrun --full <command> [args...]
    wrun --json <command> [args...]
    <command> 2>&1 | wrun --stdin [--tool pytest]

Options:
    --full              Show full output (bypass optimization)
    --max-failures N    Max failures to display (default: 10)
    --max-lines N       Max error lines per failure (default: 15)
    --json              Output as JSON
    -q, --quiet         Summary line only
    --no-save           Don't save full output to disk
    --stdin             Read from stdin instead of executing command
    --tool TOOL         Hint tool type when using --stdin
    --no-compact        Disable ultra-compact mode (use verbose format)
    -h, --help          Show this help

Examples:
    wrun uv run pytest -x tests/
    wrun bun test src/
    wrun ruff check .
    wrun tsc --noEmit
    wrun make build
    pytest tests/ 2>&1 | wrun --stdin --tool pytest

Shell integration (auto-wrap):
    source ~/.local/share/wrun/integration.zsh
    export WRUN_AUTO=1

Optimization techniques:
    - ANSI color stripping
    - Relative path normalization (worktree-aware)
    - Show only failures (skip passing tests)
    - Truncate stack traces (skip framework internals)
    - Group lint errors by rule
    - Remove decorative/progress lines
    - Cap output (max failures, max lines per failure)
    - Deduplicate identical errors
    - 1-line summary for passing runs
"""

from __future__ import annotations

import json
