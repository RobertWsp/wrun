def _meta_line(tool: str, exit_code: int, *extras: str) -> str:
    parts = [f"exit:{exit_code}", tool, *[e for e in extras if e]]
    return " | ".join(parts)


def _maybe_full_path(parts: list[str], result: Result) -> None:
    """Append `full: <path>` only when the pointer is useful.

    Useful when:
      - Any rendered line shows an explicit truncation marker (`+N more`, `... (N`),
      - Raw log has materially more lines than what was rendered (>10 lines hidden),
      - Non-zero exit with substantial raw output (>2 KB) — agent likely investigates.

    The raw log is still saved to disk; we just stop announcing it when
    everything relevant is already on screen.
    """
    if not result.raw_output_path:
        return
    truncated = any(_TRUNCATION_RE.search(p) for p in parts)
    much_hidden = result.raw_line_count > len(parts) + 10
    failed_verbose = result.exit_code != 0 and result.raw_byte_count > 2048
    if truncated or much_hidden or failed_verbose:
        display = result.raw_output_path.replace(str(Path.home()), "~")
        parts.append(f"full: {display}")


def _format_git_status(result: Result, config: Config) -> str:
    parts: list[str] = []
    branch = result.extra.get("git_branch", "")
    counts = result.extra.get("git_status_counts", {})
    entries = result.extra.get("git_status_entries", [])

    summary_bits: list[str] = []
    # Human-friendly rollup: M=modified, A=added, D=deleted, ??=untracked, U*=conflict
    label_map = {"M": "modified", "A": "added", "D": "deleted", "R": "renamed",
                 "C": "copied", "?": "untracked", "U": "conflict", "T": "typechange"}
    for code, label in label_map.items():
        total = sum(n for k, n in counts.items() if code in k)
        if total:
            summary_bits.append(f"{total} {label}")

    if not entries:
        summary_bits.append("clean")

    meta = _meta_line("git_status", result.exit_code,
                      f"on {branch}" if branch else "",
                      ", ".join(summary_bits))
    parts.append(meta)

    shown = entries[: config.max_failures * 3] if config.max_failures else entries
    for xy, path in shown:
        parts.append(f"{xy} {path}")
    remaining = len(entries) - len(shown)
    if remaining > 0:
        parts.append(f"+{remaining} more entries")

    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_git_diff(result: Result, config: Config) -> str:
    parts: list[str] = []
    totals = result.extra.get("git_diff_totals", (0, 0, 0))
    n_files, adds, dels = totals
    meta = _meta_line("git_diff", result.exit_code,
                      f"{n_files} file{'s' if n_files != 1 else ''}" if n_files else "no changes",
                      f"+{adds} -{dels}" if (adds or dels) else "")
    parts.append(meta)

    files = result.extra.get("git_diff_files", [])
    stat_rows = result.extra.get("git_diff_stat_rows", [])
    inferred = result.extra.get("git_diff_inferred_status", False)

    if files:
        shown = files[: config.max_failures * 2]
        for path, status, add, rem in shown:
            if add or rem:
                parts.append(f"{status} {path} +{add} -{rem}")
            elif inferred:
                # --name-only: emit bare path, no phantom "M " prefix
                parts.append(path)
            else:
                parts.append(f"{status} {path}")
        remaining = len(files) - len(shown)
        if remaining > 0:
            parts.append(f"+{remaining} more files")
    elif stat_rows:
        shown = stat_rows[: config.max_failures * 2]
        for _, row in shown:
            parts.append(row)
        remaining = len(stat_rows) - len(shown)
        if remaining > 0:
            parts.append(f"+{remaining} more files")

    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_git_log(result: Result, config: Config) -> str:
    parts: list[str] = []
    entries = result.extra.get("git_log_entries", [])
    meta = _meta_line("git_log", result.exit_code,
                      f"{len(entries)} commit{'s' if len(entries) != 1 else ''}")
    parts.append(meta)

    cap = max(20, config.max_failures * 2)
    shown = entries[:cap]
    for sha, subject in shown:
        subj = subject if len(subject) <= 120 else subject[:117] + "..."
        parts.append(f"{sha} {subj}")
    remaining = len(entries) - len(shown)
    if remaining > 0:
        parts.append(f"+{remaining} more commits")

    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_git_write(result: Result, config: Config) -> str:
    summary = result.extra.get("git_write_summary", "")
    return _meta_line("git_write", result.exit_code, summary)


def _format_docker_ps(result: Result, config: Config) -> str:
    parts: list[str] = []
    rows = result.extra.get("docker_rows", [])
    kind = result.extra.get("docker_kind", "ps")
    running = result.extra.get("docker_running", 0)
    stopped = result.extra.get("docker_stopped", 0)

    if kind == "images":
        summary = f"{len(rows)} image{'s' if len(rows) != 1 else ''}"
    else:
        parts_summary = []
        if running:
            parts_summary.append(f"{running} running")
        if stopped:
            parts_summary.append(f"{stopped} stopped")
        if not parts_summary:
            parts_summary.append(f"{len(rows)} container{'s' if len(rows) != 1 else ''}")
        summary = ", ".join(parts_summary)

    parts.append(_meta_line("docker_ps", result.exit_code, summary))

    cap = max(15, config.max_failures)
    shown = rows[:cap]

    for row in shown:
        if kind == "images":
            repo = row.get("REPOSITORY", "")
            tag = row.get("TAG", "")
            img_id = row.get("IMAGE ID", "")[:12]
            size = row.get("SIZE", "")
            parts.append(f"{img_id} {repo}:{tag} {size}")
            continue

        cid = row.get("CONTAINER ID", "")[:12]
        image = row.get("IMAGE", "")
        status = row.get("STATUS", "")
        ports = row.get("PORTS", "")
        name = row.get("NAMES", "")
        # Compact ports: "0.0.0.0:8080->80/tcp, [::]:8080->80/tcp" → ":8080"
        if ports:
            # Strip IPv4 and IPv6 host parts, keep host port only
            compact_ports = re.sub(r"(?:[\d.]+|\[::\]):(\d+)->\d+/\w+", r":\1", ports)
            # Deduplicate consecutive same ports (IPv4 + IPv6 of same port)
            compact_ports = re.sub(r"(:\d+),\s*\1(?=[,\s]|$)", r"\1", compact_ports)
            compact_ports = re.sub(r",\s+", ",", compact_ports)
            if len(compact_ports) > 60:
                compact_ports = compact_ports[:57] + "..."
        else:
            compact_ports = "-"
        # Compact status: "Up 2 hours (healthy)" keep, drop "Exited (0) 3 days ago" → "Exited"
        compact_status = status
        if len(compact_status) > 30:
            compact_status = compact_status[:27] + "..."
        parts.append(f"{cid} {name} {image} {compact_status} {compact_ports}")

    remaining = len(rows) - len(shown)
    if remaining > 0:
        parts.append(f"+{remaining} more")

    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_grep(result: Result, config: Config) -> str:
    parts: list[str] = []
    by_file = result.extra.get("grep_by_file", {})
    total = result.extra.get("grep_total", 0)
    unmatched = result.extra.get("grep_unmatched", [])

    if total == 0 and not unmatched:
        parts.append(_meta_line("grep", result.exit_code, "no matches"))
        return "\n".join(parts)

    parts.append(_meta_line("grep", result.exit_code,
                            f"{total} match{'es' if total != 1 else ''} in {len(by_file)} file{'s' if len(by_file) != 1 else ''}"))

    max_total = max(50, config.max_lines * 4)
    max_per_file = 10
    shown_total = 0
    files_shown = 0
    # Sort by match count desc for signal-first
    sorted_files = sorted(by_file.items(), key=lambda x: -len(x[1]))

    for path, matches in sorted_files:
        if shown_total >= max_total:
            break
        files_shown += 1
        parts.append(f"{path} ({len(matches)}):")
        per_file_cap = min(max_per_file, max_total - shown_total)
        for lineno, content in matches[:per_file_cap]:
            text = content.strip()
            if len(text) > 140:
                text = text[:137] + "..."
            # lineno=0 means grep output had no line number (rg --no-line-number)
            prefix = f"  {lineno}: " if lineno > 0 else "  "
            parts.append(f"{prefix}{text}")
        shown_total += min(per_file_cap, len(matches))
        if len(matches) > per_file_cap:
            parts.append(f"  +{len(matches) - per_file_cap} more in file")

    remaining_files = len(by_file) - files_shown
    if remaining_files > 0:
        remaining_matches = sum(len(v) for _, v in sorted_files[files_shown:])
        parts.append(f"+{remaining_files} more files ({remaining_matches} matches)")

    if unmatched:
        for line in unmatched[:3]:
            parts.append(line[:180])

    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_ls_tree(result: Result, config: Config) -> str:
    parts: list[str] = []
    entries = result.extra.get("ls_entries", [])
    hidden = result.extra.get("ls_hidden", 0)
    is_tree = result.extra.get("ls_is_tree", False)

    kinds: dict[str, int] = {}
    for kind, _ in entries:
        kinds[kind] = kinds.get(kind, 0) + 1
    summary_bits = []
    if kinds.get("D"):
        summary_bits.append(f"{kinds['D']} dirs")
    if kinds.get("F"):
        summary_bits.append(f"{kinds['F']} files")
    if kinds.get("L"):
        summary_bits.append(f"{kinds['L']} links")
    if not summary_bits:
        summary_bits.append(f"{len(entries)} entries")
    if hidden:
        summary_bits.append(f"{hidden} noise hidden")

    tool_name = "tree" if is_tree else "ls"
    parts.append(_meta_line(tool_name, result.exit_code, ", ".join(summary_bits)))

    cap = max(40, config.max_lines * 3)
    shown = entries[:cap]
    for _, display in shown:
        parts.append(display)
    remaining = len(entries) - len(shown)
    if remaining > 0:
        parts.append(f"+{remaining} more entries")

    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_docker_logs(result: Result, config: Config) -> str:
    errors = result.extra.get("docker_logs_errors", [])
    tail = result.extra.get("docker_logs_tail", [])
    total = result.extra.get("docker_logs_total", 0)
    shown = len(tail)
    summary_bits = [f"{total} lines"]
    if total > shown:
        summary_bits.append(f"last {shown} shown")
    parts: list[str] = [_meta_line("docker_logs", result.exit_code, ", ".join(summary_bits))]
    if config.quiet:
        return "\n".join(parts)
    if errors:
        parts.append(f"errors ({len(errors)}):")
        parts.extend(f"  {e}" for e in errors)
    parts.extend(tail)
    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_make(result: Result, config: Config) -> str:
    errors = result.extra.get("make_errors", [])
    warnings = result.extra.get("make_warnings", [])
    targets = result.extra.get("make_targets", [])
    total_errors = result.errors
    warn_count = len(warnings)
    parts: list[str] = [_meta_line("make", result.exit_code, f"{total_errors} errors", f"{warn_count} warnings")]
    if config.quiet:
        return "\n".join(parts)
    for e in errors:
        parts.append(f"ERR {e}")
    hidden_errors = total_errors - len(errors)
    if hidden_errors > 0:
        parts.append(f"+{hidden_errors} more errors")
    for w in warnings[:3]:
        parts.append(f"WRN {w}")
    if warn_count > 3:
        parts.append(f"+{warn_count - 3} more warnings")
    if targets:
        parts.append("targets: " + " | ".join(targets))
    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_cargo_build(result: Result, config: Config) -> str:
    errors = result.extra.get("cargo_errors", [])
    warnings = result.extra.get("cargo_warnings", 0)
    total_errors = result.errors
    parts: list[str] = [_meta_line("cargo", result.exit_code, f"{total_errors} errors", f"{warnings} warnings" if warnings else "")]
    if config.quiet:
        return "\n".join(parts)
    # Group by error code for compact output
    grouped: dict[str, list[dict]] = {}
    for e in errors:
        grouped.setdefault(e["code"], []).append(e)
    total_shown = 0
    for code, group in sorted(grouped.items(), key=lambda x: -len(x[1])):
        if total_shown >= config.max_failures:
            break
        msg = group[0]["msg"]
        if len(msg) > 120:
            msg = msg[:117] + "..."
        locs = [e["loc"] for e in group[:4] if e.get("loc")]
        loc_str = ", ".join(locs)
        remaining_in_group = len(group) - len(locs)
        if remaining_in_group > 0:
            loc_str += f" +{remaining_in_group}"
        count_str = f" x{len(group)}" if len(group) > 1 else ""
        parts.append(f"{code}{count_str}: {msg}" + (f" [{loc_str}]" if loc_str else ""))
        total_shown += 1
    hidden = total_errors - len(errors)
    if hidden > 0:
        parts.append(f"+{hidden} more errors")
    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_kubectl(result: Result, config: Config) -> str:
    mode = result.extra.get("kubectl_mode", "")
    lines = result.extra.get("kubectl_lines", [])
    total = result.extra.get("kubectl_total", 0)
    parts: list[str] = [_meta_line("kubectl", result.exit_code, mode, f"{total} lines")]
    if config.quiet:
        return "\n".join(parts)
    cap = 30
    parts.extend(lines[:cap])
    if total > cap:
        parts.append(f"+{total - cap} more lines")
    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_biome(result: Result, config: Config) -> str:
    """Compact biome output: error/warning split + duration + fixable hint."""
    errors = result.errors
    warnings = result.extra.get("biome_warnings", 0)
    checked = result.extra.get("biome_checked", 0)
    fixed = result.extra.get("biome_fixed", 0)
    skipped = result.extra.get("biome_skipped", 0)
    fixable = result.extra.get("biome_fixable", 0)
    reporter = result.extra.get("biome_reporter", "")

    # Summary bits
    status_bits: list[str] = []
    if errors:
        status_bits.append(f"{errors} error" + ("s" if errors != 1 else ""))
    if warnings:
        status_bits.append(f"{warnings} warning" + ("s" if warnings != 1 else ""))
    if not status_bits:
        status_bits.append("clean")
    if fixed:
        status_bits.append(f"{fixed} fixed")
    if skipped:
        status_bits.append(f"{skipped} skipped")

    meta_extras: list[str] = []
    if checked:
        meta_extras.append(f"{checked} file" + ("s" if checked != 1 else ""))
    if result.duration > 0:
        if result.duration < 0.001:
            meta_extras.append(f"{int(result.duration * 1_000_000)}µs")
        elif result.duration < 1:
            meta_extras.append(f"{max(1, round(result.duration * 1000))}ms")
        else:
            meta_extras.append(f"{result.duration:.2f}s")
    if reporter and reporter not in ("pretty", ""):
        meta_extras.append(f"reporter={reporter}")

    meta = _meta_line(
        "biome",
        result.exit_code,
        ", ".join(status_bits),
        *meta_extras,
    )
    parts: list[str] = [meta]

    if config.quiet:
        return "\n".join(parts)

    if result.lint_issues:
        grouped: dict[str, list[LintIssue]] = {}
        severities: dict[str, str] = {}
        for issue in result.lint_issues:
            key = issue.code or "unknown"
            grouped.setdefault(key, []).append(issue)
            # Keep highest severity per group (error > warning > info)
            prev = severities.get(key, "info")
            order = {"error": 3, "warning": 2, "info": 1}
            if order.get(issue.severity, 0) > order.get(prev, 0):
                severities[key] = issue.severity

        total_shown = 0
        sorted_groups = sorted(
            grouped.items(),
            key=lambda kv: (
                -{"error": 3, "warning": 2, "info": 1}.get(severities.get(kv[0], "error"), 0),
                -len(kv[1]),
            ),
        )
        for code, issues in sorted_groups:
            if total_shown >= config.max_failures:
                break
            msg = issues[0].message or ""
            if len(msg) > 160:
                msg = msg[:157] + "..."
            locs = []
            for iss in issues[:4]:
                loc = iss.file
                if iss.line:
                    loc += f":{iss.line}"
                locs.append(loc)
            loc_str = ", ".join(locs)
            remaining_in_group = len(issues) - len(locs)
            if remaining_in_group > 0:
                loc_str += f" +{remaining_in_group}"
            sev_tag = ""
            if severities.get(code) == "warning":
                sev_tag = " [warn]"
            elif severities.get(code) == "info":
                sev_tag = " [info]"
            parts.append(f"{code} x{len(issues)}{sev_tag}: {msg} [{loc_str}]")
            total_shown += 1

        remaining_groups = len(grouped) - total_shown
        if remaining_groups > 0:
            parts.append(f"+{remaining_groups} more rules")

    if fixable:
        parts.append(f"{fixable} fixable with --write")

    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _format_install(result: Result, config: Config) -> str:
    added = result.extra.get("install_added", 0)
    updated = result.extra.get("install_updated", 0)
    removed = result.extra.get("install_removed", 0)
    deprecated = result.extra.get("install_deprecated", [])
    pkgs = result.extra.get("install_pkgs", [])
    already = result.extra.get("install_already", 0)
    collecting = result.extra.get("install_collecting", 0)
    using = result.extra.get("install_using", 0)
    total_lines = result.extra.get("install_total_lines", 0)

    bits: list[str] = []
    if added:
        bits.append(f"{added} added")
    if updated:
        bits.append(f"{updated} updated")
    if removed:
        bits.append(f"{removed} removed")
    if pkgs:
        pkg_str = " ".join(pkgs[:5])
        if len(pkgs) > 5:
            pkg_str += f" +{len(pkgs) - 5}"
        bits.append(f"installed: {pkg_str}")
    if collecting and not pkgs and not added:
        bits.append(f"{collecting} packages")
    if using and not pkgs and not added and not collecting:
        bits.append(f"{using} packages")
    if already and not bits:
        bits.append(f"{already} already satisfied")
    if not bits:
        bits.append(f"{total_lines} lines")

    parts: list[str] = [_meta_line("install", result.exit_code, ", ".join(bits))]
    if config.quiet:
        return "\n".join(parts)
    for pkg in deprecated[:3]:
        parts.append(f"  deprecated: {pkg}")
    if len(deprecated) > 3:
        parts.append(f"  +{len(deprecated) - 3} more deprecated")
    _maybe_full_path(parts, result)
    return "\n".join(parts)


def _maybe_passthrough_tiny(result: Result, config: Config, raw_output: str, formatted: str) -> Optional[str]:
    """Return raw output (prefixed with `exit:N`) for tiny payloads where wrun's
    meta line costs more tokens than the parser saves.

    Engaged surgically: only where the parser performs no semantic transformation.
    Currently applies to `git_diff --name-only` (pure path list — parser just dropped
    the phantom `M ` prefix after the inferred-status optimization). Lint/test tools,
    grep (file grouping), git_status (rollup), git_log (graph strip), git_diff with
    real diffs/numstat/name-status (status normalization) all keep their structured
    summary because the transformation itself is the value proposition.
    """
    if config.quiet or config.json_output or config.full:
        return None
    if result.exit_code != 0:
        return None
    raw_stripped = raw_output.rstrip()
    if not raw_stripped:
        return None
    raw_bytes = len(raw_stripped.encode("utf-8"))
    if raw_bytes > 200:
        return None
    if len(formatted.encode("utf-8")) <= raw_bytes + 8:
        return None
    # git_diff --name-only: pure path list, parser adds no value → passthrough wins
    if result.tool == "git_diff" and result.extra.get("git_diff_inferred_status"):
        return f"exit:{result.exit_code}\n{raw_stripped}"
    return None


# ─── Ultra-compact transformer ────────────────────────────────────────────────

_UC_META_RE = re.compile(r"^exit:(\d+)\s*\|\s*(\S+)\s*\|\s*(.+)$")
_UC_FAIL_TEST_RE = re.compile(
    r"^FAIL\s+(\S+?)(?::(\d+))?\s*::\s*(\S+)(?:\s*[—\-]+\s*(.+))?$"
)
_UC_LINT_RE = re.compile(
    r"^(\S+)\s+x(\d+)(?:\s+\[(\w+)\])?:\s+(.+?)\s+\[([^\]]+)\]$"
)
_UC_MORE_RE = re.compile(r"^\+(\d+)\s+more.*$")
_UC_FIXABLE_RE = re.compile(r"^(\d+)\s+fixable\s+with\s+--\w+$")
_UC_FULL_RE = re.compile(r"^full:\s+(.+)$")
_UC_DOCKER_ERR_HDR_RE = re.compile(r"^errors\s+\((\d+)\):$")


def _compact_segment(seg: str) -> str:
    """Compact a single pipe-separated metadata segment."""
    seg = seg.strip()
    if not seg:
        return ""

    # "N passed, M failed" → "MF/N"
    pm = re.search(r"(\d+)\s+passed", seg)
    fm = re.search(r"(\d+)\s+failed", seg)
    if pm and fm:
        p, f = int(pm.group(1)), int(fm.group(1))
        return f"{f}F/{p + f}"
    if fm:
        return f"{fm.group(1)}F"
    if pm:
        return f"{pm.group(1)}p"

    # "N errors[, M warnings]" or "M warnings"
    em = re.search(r"(\d+)\s+errors?", seg)
    wm = re.search(r"(\d+)\s+warnings?", seg)
    if em or wm:
        parts_ew = []
        if em:
            parts_ew.append(f"{em.group(1)}e")
        if wm:
            parts_ew.append(f"{wm.group(1)}w")
        # check for additional tokens like "clean"
        rest = re.sub(r"\d+\s+errors?\s*,?\s*", "", seg)
        rest = re.sub(r"\d+\s+warnings?\s*,?\s*", "", rest).strip()
        if "clean" in rest.lower():
            parts_ew.append("clean")
        return " ".join(parts_ew)

    # status change counts: "1 modified, 2 added, 1 untracked"
    change_map = [
        ("modified", "M"), ("added", "A"), ("deleted", "D"),
        ("renamed", "R"), ("untracked", "?"), ("conflict", "C"), ("typechange", "T"),
    ]
    change_parts: list[str] = []
    for word, abbrev in change_map:
        cm = re.search(rf"(\d+)\s+{word}", seg)
        if cm:
            change_parts.append(f"{cm.group(1)}{abbrev}")
    if change_parts:
        return " ".join(change_parts)

    # "N running[, M stopped]"
    rm = re.search(r"(\d+)\s+running", seg)
    sm = re.search(r"(\d+)\s+stopped", seg)
    if rm or sm:
        res = ""
        if rm:
            res += f"{rm.group(1)}↑"
        if sm:
            res += f"{sm.group(1)}↓"
        return res

    # "N files" → Nf
    m = re.match(r"(\d+)\s+files?$", seg)
    if m:
        return f"{m.group(1)}f"

    # "N commits" → Nc
    m = re.match(r"(\d+)\s+commits?$", seg)
    if m:
        return f"{m.group(1)}c"

    # "N lines[, last M shown]" → Nl
    m = re.match(r"(\d+)\s+lines?", seg)
    if m:
        return f"{m.group(1)}l"

    # "N dirs" → Nd
    m = re.match(r"(\d+)\s+dirs?", seg)
    if m:
        return f"{m.group(1)}d"

    # "N images" → Nimg
    m = re.match(r"(\d+)\s+images?$", seg)
    if m:
        return f"{m.group(1)}img"

    # "on BRANCH" → BRANCH
    m = re.match(r"on\s+(\S+)$", seg)
    if m:
        return m.group(1)

    # "N noise hidden" → -N
    m = re.match(r"(\d+)\s+noise\s+hidden$", seg)
    if m:
        return f"-{m.group(1)}"

    # Duration: keep as-is ("0.3s", "15ms", "2.1s")
    if re.match(r"[\d.]+(?:µs|ms|s)$", seg):
        return seg

    # "+N -M" diff stats → keep as-is
    if re.match(r"[+\-]\d+", seg):
        return seg

    # reporter=X → skip (omit from ultra-compact)
    if seg.startswith("reporter="):
        return ""

    # "clean", "∅", status words → keep
    return seg


def _compact_locs_str(locs: str) -> str:
    """Compact location list: 'file:1, file2:5, +3' → 'file:1+3'"""
    more_m = re.search(r"\+(\d+)(?:\s+more)?$", locs.strip())
    more = int(more_m.group(1)) if more_m else 0

    base = locs[: more_m.start()].strip().rstrip(",").strip() if more_m else locs

    loc_parts = [ln.strip() for ln in base.split(",") if ln.strip()]
    if not loc_parts:
        return locs

    first = loc_parts[0]
    # Shorten path: keep last component only
    if "/" in first or "\\" in first:
        path_p, _, line_p = first.rpartition(":")
        if not line_p.isdigit():
            path_p, line_p = first, ""
        short = re.split(r"[/\\]", path_p)[-1]
        first = f"{short}:{line_p}" if line_p else short

    remaining = len(loc_parts) - 1 + more
    if remaining > 0:
        return f"{first}+{remaining}"
    return first


def _to_ultra_compact(text: str) -> str:
    """Transform normal wrun output to ultra-compact format."""
    lines = text.split("\n")
    out: list[str] = []

    for line in lines:
        # ── Meta line: exit:N | tool | seg1 | seg2 ... ──────────────────────
        m = _UC_META_RE.match(line)
        if m:
            exit_n, tool_name, rest = m.group(1), m.group(2), m.group(3)
            icon = "✓" if exit_n == "0" else "✗"
            segs = rest.split(" | ")
            compact_segs = [_compact_segment(s) for s in segs]
            compact_rest = " ".join(s for s in compact_segs if s)
            out.append(f"{icon}{tool_name} {compact_rest}".rstrip())
            continue

        # ── Test failure: FAIL file:line :: name — message ───────────────────
        m = _UC_FAIL_TEST_RE.match(line)
        if m:
            _file = m.group(1) or ""
            line_num = m.group(2) or ""
            test_name = m.group(3) or "?"
            message = (m.group(4) or "").strip()
            loc = f"@{line_num}" if line_num else ""
            if message:
                if len(message) > 120:
                    message = message[:117] + "..."
                out.append(f"✗{test_name}{loc}: {message}")
            else:
                out.append(f"✗{test_name}{loc}")
            continue

        # ── Lint issue: CODE xN [sev]: msg [locs] ────────────────────────────
        m = _UC_LINT_RE.match(line)
        if m:
            code = m.group(1)
            count = m.group(2)
            sev = m.group(3)
            msg = m.group(4)
            locs = m.group(5)
            count_str = f"×{count}" if int(count) > 1 else ""
            sev_str = f"[{sev[0]}]" if sev else ""
            compact_locs = _compact_locs_str(locs)
            if len(msg) > 80:
                msg = msg[:77] + "..."
            out.append(f"{code}{count_str}{sev_str} {msg}[{compact_locs}]")
            continue

        # ── "+N more X" → "+N" ───────────────────────────────────────────────
        m = _UC_MORE_RE.match(line)
        if m:
            out.append(f"+{m.group(1)}")
            continue

        # ── "N fixable with --fix/--write" → "Nfix" ──────────────────────────
        m = _UC_FIXABLE_RE.match(line)
        if m:
            out.append(f"{m.group(1)}fix")
            continue

        # ── "full: path" → "→path" ───────────────────────────────────────────
        m = _UC_FULL_RE.match(line)
        if m:
            out.append(f"→{m.group(1)}")
            continue

        # ── "errors (N):" → "err N:" ─────────────────────────────────────────
        m = _UC_DOCKER_ERR_HDR_RE.match(line)
        if m:
            out.append(f"err {m.group(1)}:")
            continue

        # ── All other lines pass through unchanged ────────────────────────────
        out.append(line)

    return "\n".join(out)


def format_result(result: Result, config: Config, raw_output: str) -> str:
    """Format the parsed result into maximum token-efficient output for LLM."""
    formatted = _format_result_impl(result, config, raw_output)
    passthrough = _maybe_passthrough_tiny(result, config, raw_output, formatted)
    result_text = passthrough if passthrough is not None else formatted
    if config.compact and not config.json_output and not config.full:
        result_text = _to_ultra_compact(result_text)
    return result_text


def _format_result_impl(result: Result, config: Config, raw_output: str) -> str:
    # Dispatch to specialized formatters for non-test tools
    if result.tool == "git_status":
        return _format_git_status(result, config)
    if result.tool == "git_diff":
        return _format_git_diff(result, config)
    if result.tool == "git_log":
        return _format_git_log(result, config)
    if result.tool == "git_write":
        return _format_git_write(result, config)
    if result.tool == "docker_ps":
        return _format_docker_ps(result, config)
    if result.tool == "docker_logs":
        return _format_docker_logs(result, config)
    if result.tool == "make":
        return _format_make(result, config)
    if result.tool == "cargo":
        return _format_cargo_build(result, config)
    if result.tool == "kubectl":
        return _format_kubectl(result, config)
    if result.tool == "grep":
        return _format_grep(result, config)
    if result.tool == "ls_tree":
        return _format_ls_tree(result, config)
    if result.tool == "biome":
        return _format_biome(result, config)
    if result.tool == "install":
        return _format_install(result, config)

    parts: list[str] = []

    # ── Summary line: exit:N | tool | counts | duration ──
    summary_parts = []
    if result.total > 0:
        if result.passed:
            summary_parts.append(f"{result.passed} passed")
        if result.failed:
            summary_parts.append(f"{result.failed} failed")
        if result.skipped:
            summary_parts.append(f"{result.skipped} skipped")
        if result.errors and result.tool not in ("ruff", "biome", "tsc", "mypy", "ty"):
            summary_parts.append(f"{result.errors} errors")

    summary_str = ", ".join(summary_parts) if summary_parts else ""
    if result.duration > 0:
        duration_str = f"{result.duration:.2f}s"
    else:
        duration_str = ""

    meta = " | ".join(filter(None, [f"exit:{result.exit_code}", result.tool, summary_str, duration_str]))
    parts.append(meta)

    # ── Quiet mode: 1-line summary regardless of outcome ──
    if config.quiet:
        return "\n".join(parts)
    # ── Passing with nothing to report: 1 line ──
    has_generic_errors = result.tool == "generic" and (result.extra.get("error_lines") or result.extra.get("summarized"))
    if (
        result.exit_code == 0
        and not result.failures
        and not result.lint_issues
        and not has_generic_errors
    ):
        return "\n".join(parts)

    # ── Test failures: compact 1-line per failure ──
    if result.failures:
        shown = result.failures[: config.max_failures]
        for f in shown:
            loc = f.file
            if f.line:
                loc += f":{f.line}"
            # Compact: FAIL file:line :: name — message
            line = f"FAIL {loc} :: {f.name}"
            if f.message:
                # Join multi-line message with | separator, cap length
                msg = f.message.replace("\n", " | ")
                if len(msg) > 200:
                    msg = msg[:197] + "..."
                line += f" — {msg}"
            parts.append(line)

        remaining = len(result.failures) - len(shown)
        if remaining > 0:
            parts.append(f"+{remaining} more failures")

    # ── Lint issues: compact grouped ──
    if result.lint_issues:
        grouped: dict[str, list[LintIssue]] = {}
        for issue in result.lint_issues:
            key = issue.code or "unknown"
            grouped.setdefault(key, []).append(issue)

        total_shown = 0
        for code, issues in sorted(grouped.items(), key=lambda x: -len(x[1])):
            if total_shown >= config.max_failures:
                break
            msg = issues[0].message
            # Compact locations on one line
            locs = [f"{iss.file}:{iss.line}" for iss in issues[:4]]
            loc_str = ", ".join(locs)
            remaining_in_group = len(issues) - len(locs)
            if remaining_in_group > 0:
                loc_str += f" +{remaining_in_group}"
            parts.append(f"{code} x{len(issues)}: {msg} [{loc_str}]")
            total_shown += 1

        remaining_groups = len(grouped) - total_shown
        if remaining_groups > 0:
            parts.append(f"+{remaining_groups} more rules")

    # ── Generic fallback: error extraction or head+tail ──
    # Always render extracted errors (exit_code may be 0 in stdin mode even when errors exist)
    if result.tool == "generic" and (result.exit_code != 0 or result.extra.get("error_lines") or result.extra.get("summarized")):
        error_lines = result.extra.get("error_lines", [])
        summarized = result.extra.get("summarized")
        total = result.extra.get("total_lines", 0)

        if error_lines:
            clean = remove_empty_and_decorative(error_lines)[:config.max_lines * 2]
            for line in clean:
                if len(line) > 500:
                    line = line[:497] + "..."
                parts.append(line)
            if total > len(clean):
                parts.append(f"... ({total - len(clean)} lines hidden, {total} total)")
        elif summarized:
            for line in summarized:
                parts.append(line)
        else:
            # Fallback: head+tail truncation
            raw_lines = raw_output.splitlines()
            clean_lines = remove_empty_and_decorative([strip_ansi(l) for l in raw_lines])

            if len(clean_lines) <= 20:
                for line in clean_lines:
                    parts.append(line)
            else:
                for line in clean_lines[:5]:
                    parts.append(line)
                parts.append(f"... ({len(clean_lines) - 20} lines hidden)")
                for line in clean_lines[-15:]:
                    parts.append(line)

    # ── Footer: fixable hint + full output path ──
    if "fixable" in result.extra:
        parts.append(f"{result.extra['fixable']} fixable with --fix")
    _maybe_full_path(parts, result)

    return "\n".join(parts)


_JSON_EXTRA_KEYS = {
    "docker_logs": ("docker_logs_errors", "docker_logs_tail", "docker_logs_total"),
    "make": ("make_errors", "make_warnings", "make_targets", "make_total_lines"),
    "cargo": ("cargo_errors", "cargo_warnings", "cargo_total_lines"),
    "kubectl": ("kubectl_mode", "kubectl_lines", "kubectl_total"),
    "biome": (
        "biome_warnings", "biome_checked", "biome_fixed",
        "biome_skipped", "biome_fixable", "biome_reporter",
    ),
}


def format_json(result: Result) -> str:
    """Format result as JSON."""
    data = {
        "tool": result.tool,
        "exit_code": result.exit_code,
        "duration": result.duration,
        "summary": {
            "total": result.total,
            "passed": result.passed,
            "failed": result.failed,
            "skipped": result.skipped,
            "errors": result.errors,
        },
        "failures": [asdict(f) for f in result.failures],
        "lint_issues_grouped": {},
        "raw_output_path": result.raw_output_path,
        "raw_line_count": result.raw_line_count,
        "raw_byte_count": result.raw_byte_count,
    }

    if result.lint_issues:
        grouped: dict[str, list[dict]] = {}
        for iss in result.lint_issues:
            key = iss.code or "unknown"
            grouped.setdefault(key, []).append(asdict(iss))
        data["lint_issues_grouped"] = grouped

    for key in _JSON_EXTRA_KEYS.get(result.tool, ()):
        if key in result.extra:
            data[key] = result.extra[key]

    return json.dumps(data, separators=(",", ":"), ensure_ascii=False)


# ─── Executor ─────────────────────────────────────────────────────────────────


def save_raw_output(output: str, tool: str) -> str:
    """Save full output to disk, return path."""
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d-%H%M%S-%f")[:20]
    path = OUTPUT_DIR / f"{ts}-{tool}.log"
    try:
        path.write_text(output, encoding="utf-8")
    except OSError:
        return ""

    # Cleanup old files (keep last 20). Tolerate concurrent deletes / stat races.
    try:
        entries: list[tuple[float, Path]] = []
        for p in OUTPUT_DIR.glob("*.log"):
            try:
                entries.append((p.stat().st_mtime, p))
            except OSError:
                continue
        entries.sort(reverse=True)
        for _, old in entries[20:]:
            try:
                old.unlink(missing_ok=True)
            except OSError:
                pass
    except OSError:
        pass

    return str(path)


def run(cmd_parts: list[str], config: Config) -> int:
    """Execute command and produce optimized output."""
    if os.environ.get("WRUN_COMPACT") == "0":
        config.compact = False
    git_root = get_git_root()
    tool = detect_tool(cmd_parts)

    # Execute command
    start = time.monotonic()
    try:
        proc = subprocess.run(
            cmd_parts,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
        )
        raw_output = proc.stdout or ""
        exit_code = proc.returncode
    except FileNotFoundError:
        sys.stderr.write(f"wrun: command not found: {cmd_parts[0]}\n")
        return 127
    except KeyboardInterrupt:
        sys.stderr.write("\nwrun: interrupted\n")
        return 130

    elapsed = time.monotonic() - start

    # Full mode: just print everything
    if config.full:
        clean = strip_ansi(raw_output)
        clean = relativize_text(clean, git_root)
        sys.stdout.write(clean)
        return exit_code

    # Clean output for parsing
    clean_output = strip_ansi(raw_output)
    clean_output = relativize_text(clean_output, git_root)

    # Save raw output
    raw_path = ""
    if not config.no_save:
        raw_path = save_raw_output(clean_output, tool)

    # Fallback: detect from output if command detection gave generic
    if tool == "generic":
        tool = detect_tool_from_output(clean_output)

    # Parse
    parser = PARSERS.get(tool, PARSERS["generic"])
    result = parser.parse(clean_output, git_root, config)
    result.exit_code = exit_code
    # Prefer tool-reported duration over wall-clock (avoids bw/Python overhead)
    if result.duration <= 0:
        result.duration = round(elapsed, 1)
    result.raw_output_path = raw_path
    result.raw_line_count = clean_output.count("\n") + (1 if clean_output and not clean_output.endswith("\n") else 0)
    result.raw_byte_count = len(clean_output.encode("utf-8"))

    # Format output
    if config.json_output:
        sys.stdout.write(format_json(result) + "\n")
    else:
        sys.stdout.write(format_result(result, config, clean_output) + "\n")

    return exit_code


# ─── CLI ──────────────────────────────────────────────────────────────────────


def parse_args(argv: list[str]) -> tuple[Config, list[str]]:
    """Parse wrun arguments, separating them from the wrapped command."""
    config = Config()
    found_command = False
    cmd_start = 0

    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg in ("-h", "--help"):
            print(__doc__)
            sys.exit(0)
        elif arg == "--full":
            config.full = True
        elif arg == "--json":
            config.json_output = True
        elif arg in ("-q", "--quiet"):
            config.quiet = True
        elif arg == "--no-save":
            config.no_save = True
        elif arg == "--stdin":
            config.stdin_mode = True
        elif arg == "--tool":
            i += 1
            if i < len(argv):
                config.tool_hint = argv[i]
        elif arg.startswith("--tool="):
            config.tool_hint = arg.split("=", 1)[1]
        elif arg == "--max-failures":
            i += 1
            if i < len(argv):
                config.max_failures = int(argv[i])
        elif arg == "--max-lines":
            i += 1
            if i < len(argv):
                config.max_lines = int(argv[i])
        elif arg.startswith("--max-failures="):
            config.max_failures = int(arg.split("=", 1)[1])
        elif arg.startswith("--max-lines="):
            config.max_lines = int(arg.split("=", 1)[1])
        elif arg == "--no-compact":
            config.compact = False
        else:
            cmd_start = i
            found_command = True
            break
        i += 1

    command = argv[cmd_start:] if found_command else []
    return config, command


def run_stdin(config: Config) -> int:
    """Process stdin and produce optimized output."""
    if os.environ.get("WRUN_COMPACT") == "0":
        config.compact = False
    git_root = get_git_root()
    raw_output = sys.stdin.read()

    # Clean output
    clean_output = strip_ansi(raw_output)
    clean_output = relativize_text(clean_output, git_root)

    # Detect tool
    if config.tool_hint and config.tool_hint in PARSERS:
        tool = config.tool_hint
    else:
        tool = detect_tool_from_output(clean_output)

    # Full mode
    if config.full:
        sys.stdout.write(clean_output)
        return 0

    # Save raw output
    raw_path = ""
    if not config.no_save:
        raw_path = save_raw_output(clean_output, tool)

    # Parse
    parser = PARSERS.get(tool, PARSERS["generic"])
    result = parser.parse(clean_output, git_root, config)
    result.exit_code = 1 if result.failed > 0 else 0
    result.raw_output_path = raw_path
    result.raw_line_count = clean_output.count("\n") + (1 if clean_output and not clean_output.endswith("\n") else 0)
    result.raw_byte_count = len(clean_output.encode("utf-8"))

    # Format output
    if config.json_output:
        sys.stdout.write(format_json(result) + "\n")
    else:
        sys.stdout.write(format_result(result, config, clean_output) + "\n")

    return result.exit_code


def main() -> None:
    if len(sys.argv) < 2 and sys.stdin.isatty():
        print(__doc__)
        sys.exit(1)

    config, command = parse_args(sys.argv[1:])

    # Stdin mode: read from pipe or --stdin flag
    if config.stdin_mode or (not command and not sys.stdin.isatty()):
        config.stdin_mode = True
        exit_code = run_stdin(config)
        sys.exit(exit_code)

    if not command:
        sys.stderr.write("wrun: no command specified\n")
        sys.exit(1)

    exit_code = run(command, config)
    sys.exit(exit_code)


if __name__ == "__main__":
    try:
        main()
    except BrokenPipeError:
        # Downstream consumer (head, less, grep -m, etc.) closed the pipe.
        # Silence stderr and exit 0 — same contract as SIG_DFL-handled SIGPIPE.
        try:
            sys.stderr.close()
        except Exception:
            pass
        sys.exit(0)
    except KeyboardInterrupt:
        sys.stderr.write("\nwrun: interrupted\n")
        sys.exit(130)
